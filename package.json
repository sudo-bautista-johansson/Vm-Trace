{
  "name": "vmtrace",
  "version": "1.0.0",
  "description": "Professional VM analysis and devirtualization tool — Ghidra for VM obfuscators",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder build --win --config"
  },
  "dependencies": {
    "cytoscape": "^3.30.4",
    "cytoscape-dagre": "^2.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/ws": "^8.5.10",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.vmtrace.app",
    "productName": "VMTrace",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png"
    }
  }
}
